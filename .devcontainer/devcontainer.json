{
    "name": "CycloneDX .NET",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
    "features": {
        "ghcr.io/devcontainers/features/dotnet:2": {
            "version": "10.0"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-dotnettools.csharp",
                "ms-dotnettools.csdevkit",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "postCreateCommand": "dotnet restore"
}
